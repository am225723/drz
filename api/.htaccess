# Protect secrets and stored submissions on Apache/Hostinger.
<Files "config.php">
  Require all denied
</Files>

<Files "config.example.php">
  Require all denied
</Files>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^secure-submissions/ - [F,L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
